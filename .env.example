# Supabase (required for saving form submissions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional — submissions still save if email is not configured)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=notifications@your-verified-domain.com

# Override recipient for testing. Leave unset in production to default to
# the gym owner's email.
NOTIFICATION_EMAIL=
